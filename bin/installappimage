#!/usr/bin/env bash

set -euo pipefail

usage() {
  printf 'Usage: %s <path-to-appimage>\n' "$(basename "$0")"
}

detect_icon_extension() {
  local icon_path="$1"
  local lower_name
  lower_name="$(printf '%s' "${icon_path##*/}" | tr '[:upper:]' '[:lower:]')"

  case "$lower_name" in
    *.png)
      printf 'png'
      return 0
      ;;
    *.svg)
      printf 'svg'
      return 0
      ;;
    *.xpm)
      printf 'xpm'
      return 0
      ;;
  esac

  if command -v file >/dev/null 2>&1; then
    case "$(file -L --mime-type -b "$icon_path" 2>/dev/null || true)" in
      image/png)
        printf 'png'
        return 0
        ;;
      image/svg+xml)
        printf 'svg'
        return 0
        ;;
      image/x-xpixmap|image/xpm)
        printf 'xpm'
        return 0
        ;;
    esac
  fi

  return 1
}

extract_appimage_root() {
  local appimage_path="$1"
  local extract_parent="$2"
  local extract_root="$extract_parent/squashfs-root"
  local offset=""

  if (cd "$extract_parent" && "$appimage_path" --appimage-extract >/dev/null 2>&1) && [[ -d "$extract_root" ]]; then
    printf '%s' "$extract_root"
    return 0
  fi

  if command -v unsquashfs >/dev/null 2>&1; then
    offset="$("$appimage_path" --appimage-offset 2>/dev/null || true)"
    if [[ "$offset" =~ ^[0-9]+$ ]] && unsquashfs -o "$offset" -d "$extract_root" "$appimage_path" >/dev/null 2>&1; then
      printf '%s' "$extract_root"
      return 0
    fi
  fi

  return 1
}

find_icon_candidate() {
  local extract_root="$1"
  local source_desktop=""
  local source_icon=""
  local candidate=""

  if [[ -e "$extract_root/.DirIcon" ]]; then
    candidate="$extract_root/.DirIcon"
  fi

  source_desktop="$(find "$extract_root" -type f -name '*.desktop' | sort | head -n 1)"
  if [[ -n "$source_desktop" ]]; then
    source_icon="$(sed -n 's/^[[:space:]]*Icon=//p' "$source_desktop" | head -n 1)"
  fi

  if [[ -z "$candidate" && -n "$source_icon" ]]; then
    if [[ "$source_icon" = /* && -f "$extract_root$source_icon" ]]; then
      candidate="$extract_root$source_icon"
    elif [[ -f "$extract_root/$source_icon" ]]; then
      candidate="$extract_root/$source_icon"
    else
      candidate="$(find "$extract_root" -type f \( -iname "${source_icon}.png" -o -iname "${source_icon}.svg" -o -iname "${source_icon}.xpm" -o -iname "$(basename "$source_icon")" \) | sort | head -n 1)"
    fi
  fi

  if [[ -z "$candidate" ]]; then
    candidate="$(find "$extract_root" -type f \( -path '*/usr/share/icons/*' -o -path '*/usr/share/pixmaps/*' -o -name '*.png' -o -name '*.svg' -o -name '*.xpm' \) | sort | head -n 1)"
  fi

  if [[ -n "$candidate" && -e "$candidate" ]]; then
    printf '%s' "$candidate"
    return 0
  fi

  return 1
}

extract_appimage_icon() {
  local appimage_path="$1"
  local icon_dir="$2"
  local icon_slug="$3"
  local temp_dir=""
  local extract_root=""
  local icon_source=""
  local icon_ext=""
  local icon_path=""

  temp_dir="$(mktemp -d)"

  extract_root="$(extract_appimage_root "$appimage_path" "$temp_dir" || true)"
  if [[ -z "$extract_root" ]]; then
    rm -rf "$temp_dir"
    return 1
  fi

  icon_source="$(find_icon_candidate "$extract_root" || true)"
  if [[ -z "$icon_source" ]]; then
    rm -rf "$temp_dir"
    return 1
  fi

  icon_ext="$(detect_icon_extension "$icon_source" || true)"
  if [[ -z "$icon_ext" ]]; then
    rm -rf "$temp_dir"
    return 1
  fi

  mkdir -p "$icon_dir"
  icon_path="$icon_dir/$icon_slug.$icon_ext"
  cp -fL "$icon_source" "$icon_path"
  chmod 0644 "$icon_path"
  rm -rf "$temp_dir"
  printf '%s' "$icon_path"
}

strip_version_suffix() {
  local name="$1"
  local stripped="$name"
  local previous=""

  while [[ "$stripped" != "$previous" ]]; do
    previous="$stripped"
    stripped="$(printf '%s\n' "$stripped" | sed -E \
      's/([[:space:]_.-])v?[0-9]+([.][0-9]+)+([._-]?(alpha|beta|rc)([._-]?[0-9]+)?)?([[:space:]_.-]|$)/\1/g;
       s/([[:space:]_.-])v?[0-9]{4,}([[:space:]_.-]|$)/\1/g;
       s/^[[:space:]_.-]+//;
       s/[[:space:]_.-]+$//;
       s/[[:space:]_.-]{2,}/-/g')"
  done

  if [[ -n "$stripped" ]]; then
    printf '%s' "$stripped"
  else
    printf '%s' "$name"
  fi
}

if [[ $# -ne 1 ]]; then
  usage
  exit 1
fi

input_path="$1"

if [[ ! -f "$input_path" ]]; then
  printf 'Error: file not found: %s\n' "$input_path" >&2
  exit 1
fi

case "$input_path" in
  *.AppImage|*.appimage|*.Appimage)
    ;;
  *)
    printf 'Warning: file does not use a typical AppImage extension: %s\n' "$input_path" >&2
    ;;
esac

install_dir="$HOME/.local/bin/appimages"
desktop_dir="$HOME/.local/share/applications"
icon_dir="$HOME/.local/share/icons/appimages"

mkdir -p "$install_dir" "$desktop_dir"

input_abs="$(realpath "$input_path")"
original_name="$(basename "$input_abs")"
if [[ "$original_name" == *.* ]]; then
  original_stem="${original_name%.*}"
  extension=".${original_name##*.}"
else
  original_stem="$original_name"
  extension=""
fi

stable_stem="$(strip_version_suffix "$original_stem")"
app_name="$(printf '%s' "$stable_stem" | tr '.-' '  ' | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//')"
if [[ -z "$app_name" ]]; then
  app_name="$stable_stem"
fi

# Keep desktop file name launcher-safe.
desktop_slug="$(printf '%s' "$stable_stem" | tr '[:space:]' '-' | tr -cd '[:alnum:]_.-')"
if [[ -z "$desktop_slug" ]]; then
  desktop_slug="appimage-app"
fi

installed_path="$install_dir/$stable_stem$extension"
desktop_path="$desktop_dir/$desktop_slug.desktop"
icon_path=""

cp -f "$input_abs" "$installed_path"
chmod +x "$installed_path"

icon_path="$(extract_appimage_icon "$installed_path" "$icon_dir" "$desktop_slug" || true)"

if [[ -e "$desktop_path" && ! -f "$desktop_path" ]]; then
  printf 'Error: desktop path exists but is not a file: %s\n' "$desktop_path" >&2
  exit 1
fi

desktop_created=false
if [[ ! -e "$desktop_path" ]]; then
  {
    cat <<EOF
[Desktop Entry]
Type=Application
Version=1.0
Name=$app_name
Exec="$installed_path"
Terminal=false
Categories=Utility;
X-AppImage-Integrate=false
EOF
    if [[ -n "$icon_path" ]]; then
      printf 'Icon=%s\n' "$icon_path"
    fi
  } > "$desktop_path"

  chmod 0644 "$desktop_path"
  desktop_created=true
elif [[ -n "$icon_path" ]] && ! grep -Eq '^[[:space:]]*Icon=' "$desktop_path"; then
  printf 'Icon=%s\n' "$icon_path" >> "$desktop_path"
fi

if command -v update-desktop-database >/dev/null 2>&1; then
  update-desktop-database "$desktop_dir" >/dev/null 2>&1 || true
fi

printf 'Installed AppImage: %s\n' "$installed_path"
if [[ -n "$icon_path" ]]; then
  printf 'Extracted icon:      %s\n' "$icon_path"
fi
if [[ "$desktop_created" == true ]]; then
  printf 'Desktop entry:      %s\n' "$desktop_path"
else
  printf 'Desktop entry kept: %s\n' "$desktop_path"
fi
printf 'You can now launch "%s" from your app launcher.\n' "$app_name"
